# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (optional — leave empty to disable GA)
NEXT_PUBLIC_GA_ID=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Required in production for the contact form to send emails.
# Get your key at https://resend.com/api-keys
# Without this key the form still works — submissions are logged to console instead.
RESEND_API_KEY=

# ─── Site ─────────────────────────────────────────────────────────────────────
# Public URL of the deployed site (no trailing slash).
# Used for canonical URLs, OG metadata, and the sitemap.
NEXT_PUBLIC_SITE_URL=https://www.sanurride.co
